    {
      "parameters": {
        "url": "https://localclawagents.com/api/alerts",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"agent_id\": \"{{ $json.agent_id }}\",\n  \"business\": \"{{ $json.business_name }}\",\n  \"severity\": \"warning\",\n  \"type\": \"follow_up_escalation\",\n  \"message\": \"3 unanswered follow-ups for {{ $json.customer_name }} — escalated to owner\",\n  \"customer_id\": \"{{ $json.id }}\",\n  \"timestamp\": \"{{ $now.toISO() }}\"\n}",
        "options": {}
      },
      "id": "localclaw-alert",
      "name": "LocalClaw — Send Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1780, 560],
      "credentials": {
        "httpHeaderAuth": {
          "id": "localclaw-api-creds",
          "name": "LocalClaw API Key"
        }
      }
